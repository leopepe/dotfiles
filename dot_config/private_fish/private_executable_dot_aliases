alias cdp='cd $HOME/Workspace/data-platform'
alias cop='cd $HOME/Workspace/data-platform/data-operations'
alias rs='cd $HOME/Workspace/rust'
alias py='cd $HOME/Workspace/python/'
alias docs='cd $HOME/Documents'

# data-eng
alias tunnel_dev='ssh -v -i ~/.ssh/moia-analytics-dev.pem -NL 5439:10.0.112.15:5439 ec2-user@18.197.197.226'
# alias tunnel_int='ssh -v -i ~/.ssh/moia-analytics-int.pem -NL 5439:10.0.112.227:5439 ec2-user@18.197.170.117'
alias tunnel_int='ssh -v -i ~/.ssh/moia-analytics-int.pem -NL 5439:10.0.112.227:5439 ec2-user@35.157.255.237'
alias tunnel_prd='ssh -v -i ~/.ssh/moia-analytics-prd.pem -NL 5439:10.1.12.140:5439 ec2-user@18.197.193.96'
alias aws_vault_server_dev='aws-vault exec dev -s --debug --prompt=osascript -- tail -f /dev/null'
alias aws_vault_server_int='aws-vault exec int -s --debug --prompt=osascript -- tail -f /dev/null'
alias aws_vault_server_prd='aws-vault exec prd -s --debug --prompt=osascript -- tail -f /dev/null'
alias local_batch_job_dev='DB_NAME=development DB_HOST=localhost DB_PORT=5439 DB_USER=analytics_cluster_dwh_loader STAGE=dev aws-vault exec dev -- poetry run python main.py --local_run=1'
alias local_batch_job_int='DB_NAME=integration DB_HOST=localhost DB_PORT=5439 DB_USER=analytics_cluster_dwh_loader STAGE=int aws-vault exec int -- poetry run python main.py --local_run=1'
alias bastion_socks5='tmux new-session -s tunnels "autossh -M 20001 -vND 10001 bastion_dev" \; split-window -d "autossh -M 20011 -vND 10011 bastion_int" \; split-window -d "autossh -M 20021 -vND 10021 bastion_prd" \; select-layout even-horizontal'

# tools
